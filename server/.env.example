# Taskly server environment template
# Use `.env` for shared defaults, `.env.local` for local development, `.env.production` for production.

NODE_ENV=development
APP_NAME=Taskly API
APP_VERSION=1.0.0
PORT=5000
API_PREFIX=/api/v1

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/taskly_db_dev"

# JWT and sessions
JWT_SECRET=replace_with_a_32_plus_character_secret
JWT_REFRESH_SECRET=replace_with_a_second_32_plus_character_secret
ACCESS_TOKEN_EXPIRATION=365d
REFRESH_TOKEN_EXPIRATION=7d
SESSION_SECRET=replace_with_a_32_plus_character_session_secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASSWORD=

# Monitoring
SENTRY_DSN=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/auth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:5000/api/v1/auth/facebook/callback

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=Taskly
EMAIL_SECURE=true
SENDGRID_API_KEY=
EMAIL_PROVIDER=sendgrid
VERIFICATION_METHOD=BOTH

# CORS and client URLs
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Storage
STORAGE_TYPE=LOCAL
LOCAL_STORAGE_BASE_URL=http://localhost:5000
LOCAL_STORAGE_BASE_URL_DEV=http://localhost:5000
LOCAL_STORAGE_BASE_URL_PROD=https://api.example.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET_NAME=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
R2_ENDPOINT=

# Revalidation and database tuning
REVALIDATION_SECRET_KEY=replace_with_revalidation_secret
DB_POOL_SIZE=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000
